# Helix Runtime 配置示例
# 复制为 .env 并修改配置

# 应用基本配置
DEBUG=true

# 运行时约束
MAX_RECENT_TURNS=5
MAX_HISTORY_TURNS=5
MAX_WORKFLOW_STEPS=3
MAX_PROMPT_TOKENS=4096
MAX_WORKFLOW_RETRY=2

# Redis 配置（可选）
# REDIS_URL=redis://localhost:6379/0

# PostgreSQL 配置（可选）
# DATABASE_URL=postgresql://user:pass@localhost:5432/helix
